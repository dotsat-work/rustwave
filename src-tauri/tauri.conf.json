{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rustwave",
  "version": "0.1.0",
  "identifier": "work.dotsat.rustwave",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "brainfm",
        "title": "Rustwave",
        "width": 1024,
        "height": 768,
        "transparent": true,
        "decorations": true,
        "url": "https://www.brain.fm/app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
